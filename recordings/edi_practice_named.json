{
    "title": "練習EDI 検収照会（フレームを名前で指定する版・Codegen 由来）",
    "steps": [
        { "type": "setViewport", "width": 1250, "height": 1000 },
        { "type": "navigate", "url": "http://localhost:8000/edi/index.html" },
        {
            "type": "change",
            "value": "{{SECRET:MY_USERNAME}}",
            "target": "main",
            "selectors": [["#username"]]
        },
        {
            "type": "change",
            "value": "{{SECRET:MY_PASSWORD}}",
            "target": "main",
            "selectors": [["#password"]]
        },
        {
            "type": "click",
            "target": "main",
            "selectors": [["aria/Login"], ["#loginBtn"], ["text/Login"]]
        },
        {
            "type": "click",
            "target": "main",
            "frame": "menu",
            "selectors": [["aria/検収照会"], ["#linkKenshu"], ["text/検収照会"]]
        },
        {
            "type": "change",
            "value": "{{yyyymm}}",
            "target": "main",
            "frame": "content",
            "selectors": [["#yyyymm"]]
        },
        {
            "type": "click",
            "target": "main",
            "frame": "content",
            "selectors": [["#searchBtn"], ["text/検 索"]]
        }
    ]
}
